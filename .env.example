# Data paths
DATA_DIR=data
DUCKDB_PATH=data/pmgetrich.duckdb

# Model settings
CHRONOS_MODEL=amazon/chronos-t5-small
DEVICE=cpu

# Divergence thresholds
DIVERGENCE_THRESHOLD=0.05
DIVERGENCE_LOOKBACK_DAYS=30

# Market selection criteria
MIN_VOLUME=1000
MIN_LIQUIDITY=500
MAX_MARKETS=100

# HuggingFace
HF_DATASET=polymarket/market-data
